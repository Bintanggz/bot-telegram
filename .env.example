# Telegram Bot Token (dapatkan dari @BotFather di Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Key (dapatkan dari https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=bot_tele_db
DB_PORT=3306

# Express Server Port (Optional)
PORT=3000

# Security (Optional: Masukkan ID Telegram Anda jika ingin bot privat/dibatasi hanya untuk Anda)
ALLOWED_TELEGRAM_ID=

